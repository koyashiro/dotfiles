{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(fd:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(diff:*)",
      "Bash(pwd:*)",
      "Bash(realpath:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(cargo build:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo test:*)",
      "Bash(cargo fmt:*)",
      "Bash(cargo doc:*)",
      "Bash(cargo check:*)",
      "Bash(go build:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go doc:*)",
      "Bash(go list:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint run:*)",
      "Bash(npm run build:*)",
      "Bash(npm run list:*)",
      "Bash(npm run format:*)",
      "Bash(npm run fmt:*)",
      "Bash(npx tsc:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(npx jest:*)",
      "Bash(npx vitest:*)",
      "WebSearch",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:hub.docker.com)",
      "WebFetch(domain:docs.timescale.com)",
      "WebFetch(domain:stackoverflow.com)",
      "WebFetch(domain:stackexchange.com)",
      "WebFetch(domain:doc.rust-lang.org)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:nodejs.org)",
      "WebFetch(domain:npmjs.com)",
      "WebFetch(domain:typescriptlang.org)",
      "WebFetch(domain:go.dev)",
      "WebFetch(domain:pkg.go.dev)",
      "WebFetch(domain:proxy.golang.org)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.gnupg/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.bash_history)",
      "Read(~/.local/state/bash/history)",
      "Read(~/.zsh_history)",
      "Read(~/.local/state/zsh/history)",
      "Read(~/.mysql_history)",
      "Read(~/.local/state/mysql/history)",
      "Read(~/.psql_history)",
      "Read(~/.local/state/pg/history)",
      "Read(~/.sqlite_history)",
      "Read(~/.local/state/sqlite/history)",
      "Read(~/.rediscli_history)",
      "Read(~/.local/state/redis/history)",
      "Read(~/.git-credentials)",
      "Read(~/.config/git/credentials)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.config/claude/.credentials.json)",
      "Read(~/.config/gh/hosts.yml)",
      "Read(~/.kube/**)",
      "Read(~/.config/kube/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/aws/**)"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
